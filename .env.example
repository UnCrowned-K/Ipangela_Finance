# Profit Optimizer Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Secret key for Flask sessions (change in production!)
SECRET_KEY=your-secret-key-change-in-production

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server host and port
HOST=0.0.0.0
PORT=5000

# Debug mode (only for development)
DEBUG=true

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================

# Maximum file upload size (in bytes)
MAX_CONTENT_LENGTH=16777216  # 16MB

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# SMTP settings for sending invoices
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password

# =============================================================================
# DATABASE SETTINGS (Optional - for future PostgreSQL support)
# =============================================================================

# Database URL (format: postgresql://user:password@host:port/database)
DATABASE_URL=

# =============================================================================
# API SETTINGS
# =============================================================================

# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# CORS origins (comma-separated for multiple origins)
CORS_ORIGINS=*

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Gunicorn workers (adjust based on server resources)
GUNICORN_WORKERS=2

# Gunicorn threads
GUNICORN_THREADS=4

# =============================================================================
# VERCEL SETTINGS
# =============================================================================

# Vercel deployment (automatic)
VERCEL=true
